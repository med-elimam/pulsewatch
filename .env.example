# ---- Pulsewatch configuration ----
# Required in production:
SECRET=change-me-to-a-long-random-string     # signs session cookies (openssl rand -hex 32)
APP_URL=https://app.yourdomain.com           # public base URL (used to build ping URLs & email links)
NODE_ENV=production

# Storage (SQLite file). Use a mounted volume/persistent disk in production.
DB_PATH=./data/pulsewatch.db

# Failure-check frequency (ms). 15000 = check every 15s.
CHECK_INTERVAL_MS=15000
PORT=3000

# ---- Email alerts (choose ONE). If unset, alerts still fire but only log. ----
# Option A: Resend HTTP API (easiest)
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=Pulsewatch <alerts@yourdomain.com>
# MAIL_REPLY_TO=support@yourdomain.com   # optional Reply-To

# Option B: any SMTP provider (Postmark, Gmail, Mailgun, SES...)
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=your-user
# SMTP_PASS=your-pass
# MAIL_FROM=Pulsewatch <alerts@yourdomain.com>

# ---- Slack alerts ----
# Per-monitor webhooks are set in the UI. This is an optional account-wide fallback:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ---- Billing: Paddle (merchant of record). Prices are PUBLIC on /pricing and must match Paddle. ----
# Until PADDLE_CLIENT_TOKEN is set, checkout buttons show: "Paddle checkout is being activated. Contact support to upgrade."
PADDLE_ENV=production            # sandbox | production
PADDLE_API_KEY=                  # server-side API key (for future webhook verification / API calls)
PADDLE_CLIENT_TOKEN=             # client-side token used by Paddle.js to open checkout
PADDLE_STARTER_PRICE_ID=         # Paddle price ID for Starter ($5/month)
PADDLE_PRO_PRICE_ID=             # Paddle price ID for Pro ($12/month)
PADDLE_TEAM_PRICE_ID=            # Paddle price ID for Team ($29/month)
PADDLE_WEBHOOK_SECRET=           # Paddle webhook signing secret (for subscription events)

# ---- Legal / support (shown on /terms, /privacy, /refund, /contact) ----
COMPANY_NAME=Pulsewatch
LEGAL_EMAIL=support@maurisis.com # falls back in copy to medlimame9@gmail.com if you have no domain inbox
